            { "Line": "Piccadilly","Swatch":{ "type": "color-swatch", "color": "#003688" }, "Opened": "1906", "Stations": "53", "Character": "Dark blue. The airport line; connects Heathrow to the West End." },
            { "Line": "Victoria", "Swatch": { "type": "color-swatch", "color": "#0098D4" }, "Opened": "1968", "Stations": "16", "Character": "Light blue. The fastest and most automated line on the network." }
          ]
        }
      ],
      "speakerNotes": "One principle from earlier deserves a closer look — the colour per line rule..."
    },
    {
      "index": 9,
      "label": "09 Johnston Sans and Beck Quote",
      "screenshot": "slides/slide-09.png",
      "background": "#F5F1E8",
      "layout": "image-left-quote-right",
      "elements": [
        {
          "type": "image", "id": "specimen",
