        {
          "type": "richText", "id": "attribution",
          "x": 720, "y": 802, "width": 1120,
          "runs": [
            { "text": "HARRY BECK", "weight": 700, "size": 24, "color": "#0B1B33", "letterSpacing": 4 },
            { "text": " · c. 1933, in an unpublished note", "size": 24, "color": "#5A6B82" }
