          "x": 1008, "y": 310, "width": 832,
          "font": "EB Garamond", "size": 68, "weight": 700,
          "color": "#FFFFFF", "lineHeight": 1.1
        },
        {
          "type": "text", "id": "body",
          "text": "Straight lines. Three angles. Interchange diamonds. A blue ribbon for the Thames. Everything else is colour, type, and the silence around them.",
          "x": 1008, "y": 576, "width": 832,
          "font": "Calibri", "style": "italic", "size": 28,
          "color": "#DCE3F1", "lineHeight": 1.6
        }
      ],
      "speakerNotes": "I want to pause on this image because it's relevant. This is a Tube escalator..."
    },
