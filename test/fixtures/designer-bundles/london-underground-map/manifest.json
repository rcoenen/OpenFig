          "steps": [
            { "year": "1931", "color": "#9B0056", "event": "Sketch", "description": "Beck, laid off from the signalling office, drafts the diagram at home." },
            { "year": "1932", "color": "#DC241F", "event": "Rejected", "description": "Publicity office rules the design too radical and returns it." },
