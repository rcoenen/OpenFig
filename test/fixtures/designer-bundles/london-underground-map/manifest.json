          "yAxis": { "min": 0, "max": 800000, "ticks": [0, 200000, 400000, 600000, 800000] },
          "series": [{ "data": [50000, 130000, 230000, 330000, 450000, 560000, 660000, 740000], "color": "#0B1B33" }],
          "annotations": [{ "x": 4, "label": "Reprint ordered", "color": "#DC241F" }],
          "note": "Figures are illustrative, reconstructed from period accounts."
        }
      ],
      "speakerNotes": "The public reaction was immediate. When Beck's map was published as a pocket edition in January 1933, London Transport printed 750,000 copies..."
    },
    {
      "index": 7,
      "label": "07 From Sketch to Standard",
      "screenshot": "slides/slide-07.png",
