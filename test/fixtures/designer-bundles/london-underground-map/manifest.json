        },
        {
          "type": "text", "id": "subtitle",
          "text": "Beck's insistence on a unique colour for every line survives to this day. The official TfL palette:",
          "x": 86, "y": 155, "width": 1748,
          "font": "Calibri", "style": "italic", "size": 25, "color": "#5A6B82"
        },
        {
