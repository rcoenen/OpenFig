        },
        {
          "type": "text", "id": "spec-cap2",
          "text": "Commissioned for the Underground",
          "x": 115, "y": 920, "width": 504,
          "align": "center", "font": "Calibri", "style": "italic", "size": 24, "color": "#5A6B82"
        },
        {
          "type": "text", "id": "quote-mark",
